#!/bin/bash

# Colores Estilo cr1odots
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Rutas
VENV_PATH="$HOME/.local/share/uv/tools/qtile"
QTILE_DIR="$HOME/qtile"
EXTRAS_DIR="$HOME/qtile-extras"
CONFIG_DIR="$HOME/.config/qtile"
REPO_CONFIG="TU_URL_DE_GITHUB_AQUI" # <--- CAMBIÁ ESTO CON TU REPO DE DOTFILES

# Función para limpiar pantalla y mostrar cabecera
show_header() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${CYAN}      Qtile UV Manager - Menú Interactivo  ${NC}"
    echo -e "${CYAN}==========================================${NC}"
}

# Lógica de las funciones existentes
do_full_install() {
    echo -e "${GREEN} Instalando librerías de sistema...${NC}"
    sudo apt update && sudo apt install -y libwayland-dev libwlroots-dev libxkbcommon-dev libpangocairo-1.0-0 git libiw-dev python3-pip
    [ ! -d "$QTILE_DIR" ] && git clone https://github.com/qtile/qtile.git "$QTILE_DIR"
    cd "$QTILE_DIR" && uv tool install .
    [ ! -d "$EXTRAS_DIR" ] && git clone https://github.com/elParaguayo/qtile-extras.git "$EXTRAS_DIR"
    uv pip install --python "$VENV_PATH" "$EXTRAS_DIR"
    uv pip install --python "$VENV_PATH" iwlib requests dbus-fast pulsectl-asyncio psutil pywayland xkbcommon
    sudo bash -c "cat <<EOF > /usr/share/wayland-sessions/qtile.desktop
[Desktop Entry]
Name=Qtile (Wayland) - UV
Exec=$HOME/.local/bin/qtile start -b wayland
Type=Application
EOF"
}

do_sync_config() {
    if [ "$REPO_CONFIG" == "TU_URL_DE_GITHUB_AQUI" ]; then
        echo -e "${RED}Error: Configurá la URL de tu repo en el script.${NC}"
    else
        if [ ! -d "$CONFIG_DIR" ]; then
            git clone "$REPO_CONFIG" "$CONFIG_DIR"
        else
            cd "$CONFIG_DIR" && git pull
        fi
        echo -e "${GREEN}Configuración sincronizada.${NC}"
    fi
}

# --- MENÚ PRINCIPAL ---
show_header
echo -e "Elija una opción:"
echo -e "${GREEN}1)${NC} Instalación Completa (Desde cero)"
echo -e "${GREEN}2)${NC} Actualizar Todo (Core + Extras)"
echo -e "${GREEN}3)${NC} Sincronizar Configuración (.config/qtile)"
echo -e "${GREEN}4)${NC} Inyectar un paquete nuevo"
echo -e "${GREEN}5)${NC} Chequear errores en la config"
echo -e "${RED}6)${NC} Salir"
echo -e ""
read -p "Opción [1-6]: " opcion

case $opcion in
    1)
        do_full_install
        read -p "¿Querés bajar tu configuración de GitHub ahora? (s/n): " resp
        [[ "$resp" =~ ^[Ss]$ ]] && do_sync_config
        ;;
    2)
        echo -e "${GREEN}Actualizando...${NC}"
        cd "$QTILE_DIR" && git pull && uv tool upgrade qtile
        cd "$EXTRAS_DIR" && git pull && uv pip install --python "$VENV_PATH" .
        ;;
    3)
        do_sync_config
        ;;
    4)
        read -p "Nombre del paquete a inyectar: " paquete
        uv pip install --python "$VENV_PATH" "$paquete"
        ;;
    5)
        uv pip install --python "$VENV_PATH" --upgrade mypy > /dev/null
        "$HOME/.local/bin/qtile" check
        ;;
    6)
        echo -e "${CYAN}¡Nos vemos, Cristian!${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}Opción no válida.${NC}"
        ;;
esac

echo -e "\n${YELLOW}Proceso terminado. Presioná Enter para salir.${NC}"
read
